  "description": "Convention linter for AI agents — CLI & MCP server",
  "type": "module",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "bin": {
    "fret": "./build/index.js"
  },
  "files": [
    "build/",
    "README.md",
